DATABASE_URL=postgresql://kbs:kbs@localhost:5432/knowledge
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_chunks
VECTOR_ENABLED=1
VECTOR_DIM=384

# Host ports (change when port conflict happens)
KB_PORT_API=8000
KB_PORT_POSTGRES=5432
KB_PORT_QDRANT=6333
KB_PORT_MINIO_API=9000
KB_PORT_MINIO_CONSOLE=9001
KB_PORT_PROMETHEUS=9090
KB_PORT_GRAFANA=3000

# LLM (answer/enrichment)
KB_LLM_ENABLED=0
KB_LLM_API_KEY=
KB_LLM_BASE_URL=https://api.openai.com/v1
KB_LLM_MODEL=gpt-4o-mini
KB_LLM_TIMEOUT_SEC=30

# Embedding (retrieval vectorization)
KB_EMBEDDING_ENABLED=0
KB_EMBEDDING_API_KEY=
KB_EMBEDDING_BASE_URL=https://api.openai.com/v1
KB_EMBEDDING_MODEL=
KB_EMBEDDING_DIM=384
KB_EMBEDDING_TIMEOUT_SEC=20

# Rerank (retrieval precision)
KB_RERANK_ENABLED=0
KB_RERANK_API_KEY=
KB_RERANK_BASE_URL=https://api.openai.com/v1
KB_RERANK_MODEL=
KB_RERANK_PATH=/rerank
KB_RERANK_TIMEOUT_SEC=20

# Import-time metadata enrichment
KB_ENRICHMENT_ENABLED=0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
# ⚠️ 生产部署前必须改为强随机值（仅 PostgreSQL 后端使用，直装版不读取）
MINIO_SECRET_KEY=change_me_in_production
API_BASE_IMAGE=m.daocloud.io/docker.io/library/python:3.12-slim
